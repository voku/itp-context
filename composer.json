{
  "name": "voku/itp-context",
  "description": "Architecture context attributes, catalogs, validation and summarization helpers for PHP projects.",
  "type": "library",
  "keywords": [
    "architecture",
    "attribute",
    "catalog",
    "context",
    "enum",
    "php",
    "rule"
  ],
  "homepage": "https://github.com/voku/itp-context",
  "license": "MIT",
  "authors": [
    {
      "name": "Lars Moelleken",
      "email": "lars@moelleken.org",
      "homepage": "https://www.moelleken.org/"
    }
  ],
  "support": {
    "issues": "https://github.com/voku/itp-context/issues",
    "source": "https://github.com/voku/itp-context"
  },
  "require": {
    "php": ">=8.3.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "ItpContext\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ItpContext\\Tests\\": "tests/",
      "ItpContextExample\\": "examples/basic-domain/src/"
    }
  },
  "bin": [
    "bin/itp-context-summarize",
    "bin/itp-context-validate",
    "bin/itp-context-generate",
    "bin/itp-context-export"
  ],
  "scripts": {
    "phpstan": "phpstan analyse --configuration=phpstan.neon.dist",
    "test": "phpunit"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "0.1.x-dev"
    }
  }
}
